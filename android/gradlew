#!/bin/sh

##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#   IMPORTANT: This script requires the full Gradle wrapper package.
#   Download from: https://services.gradle.org/distributions/gradle-8.2-bin.zip
#   Extract and copy gradle/wrapper/ to android/gradle/wrapper/
#
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Determine the Java command to use to start the JVM
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

# For Cygwin or MSYS, switch paths to Windows format before running java
case "$(uname)" in
    CYGWIN*|MINGW*) APP_HOME=$(cygpath --path --mixed "$APP_HOME";;
esac

exec "$JAVACMD" \
    $DEFAULT_JVM_OPTS \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"